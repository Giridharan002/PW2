# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/resume-portfolio

# Frontend URL used in CORS + email links
FRONTEND_URL=http://localhost:5173

# Required AI key (server throws on startup when missing)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional AI / Jobs / Email integrations
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
JSEARCH_API_KEY=
RESEND_API_KEY=
EMAIL_USER=

# Optional scheduler override (cron)
JOB_DIGEST_SCHEDULE=0 9 * * *
